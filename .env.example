# =============================================================================
# Heatr — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co        # Project URL from Supabase dashboard → Settings → API
SUPABASE_KEY=your_service_role_key                   # Service role key (NOT anon key) — full DB access
SUPABASE_STORAGE_BUCKET=screenshots                  # Storage bucket name for website screenshots

# -----------------------------------------------------------------------------
# Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...                         # Anthropic API key — Haiku for bulk, Sonnet for Vision

# -----------------------------------------------------------------------------
# KvK (Kamer van Koophandel)
# -----------------------------------------------------------------------------
KVK_API_KEY=your_kvk_api_key                         # KvK API key — email fallback step 4, NL only

# -----------------------------------------------------------------------------
# Warmr
# -----------------------------------------------------------------------------
WARMR_API_URL=https://your-warmr.com/api/v1          # Base URL of your Warmr instance
WARMR_API_KEY=your_warmr_api_key                     # Warmr API key for push/campaign endpoints
WARMR_WEBHOOK_SECRET=your_hmac_secret                # HMAC secret to verify incoming Warmr webhooks

# -----------------------------------------------------------------------------
# Playwright
# -----------------------------------------------------------------------------
PLAYWRIGHT_HEADLESS=true                             # true = headless Chromium, false = visible (debug)
SCRAPE_DELAY_MIN=2                                   # Minimum seconds between page actions (anti-detection)
SCRAPE_DELAY_MAX=6                                   # Maximum seconds between page actions (anti-detection)
MAX_CONCURRENT_SCRAPERS=3                            # Max parallel Playwright browser contexts
GOOGLE_MAPS_MAX_RESULTS=60                           # Max leads to scrape per Google Maps search

# -----------------------------------------------------------------------------
# Proxy (disabled by default)
# -----------------------------------------------------------------------------
PROXY_ENABLED=false                                  # Set true to route Playwright through a proxy
PROXY_URL=http://user:pass@proxy.host:port           # Full proxy URL with credentials
PROXY_COUNTRY=NL                                     # Request NL exit node (for NL-specific content)

# -----------------------------------------------------------------------------
# Enrichment
# -----------------------------------------------------------------------------
EMAIL_VERIFY_TIMEOUT=10                              # Seconds before SMTP verification times out
MAX_CONCURRENT_ENRICHMENTS=5                         # Max leads enriching in parallel
CATCHALL_CHECK_ENABLED=true                          # Detect and penalise catch-all email servers

# -----------------------------------------------------------------------------
# Website Intelligence
# -----------------------------------------------------------------------------
PAGESPEED_API_KEY=your_google_pagespeed_api_key      # Google PageSpeed Insights API key (free tier: 400 req/day)
SCREENSHOT_ENABLED=true                              # Enable Playwright full-page screenshots
COMPETITOR_ANALYSIS_ENABLED=true                     # Enable Layer 5 competitor comparison
COMPETITOR_COUNT=3                                   # Number of local competitors to compare against

# -----------------------------------------------------------------------------
# Scoring / Warmr push thresholds
# -----------------------------------------------------------------------------
MIN_SCORE_FOR_WARMR=65                               # Lead score minimum to allow Warmr push
MIN_ICP_MATCH_FOR_WARMR=0.6                          # ICP match minimum (0.0–1.0) to allow Warmr push
MIN_WEBSITE_SCORE_FOR_OPPORTUNITY=50                 # Website scores below this flag an opportunity
AUTO_PUSH_TO_WARMR=false                             # If true, qualified leads push automatically (risky!)

# -----------------------------------------------------------------------------
# GDPR
# -----------------------------------------------------------------------------
GDPR_MODE=strict                                     # strict = personal emails blocked; relaxed = warned only

# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------
DEFAULT_WORKSPACE_ID=aerys                           # Default workspace slug for single-tenant deploys
