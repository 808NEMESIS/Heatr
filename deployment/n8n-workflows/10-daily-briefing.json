{
  "name": "10 — Daily Briefing",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 7 * * *" }]
        }
      },
      "name": "Daily at 07:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.HEATR_BASE_URL }}/briefing/generate",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "name": "Generate briefing",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    }
  ],
  "connections": {
    "Daily at 07:00": { "main": [[{ "node": "Generate briefing", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
