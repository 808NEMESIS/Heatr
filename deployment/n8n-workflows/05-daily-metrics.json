{
  "name": "05 — Daily Metrics Collection",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "55 23 * * *" }]
        }
      },
      "name": "Daily at 23:55",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.HEATR_BASE_URL }}/analytics/collect-metrics",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": { "parameters": [] },
        "options": {}
      },
      "name": "Collect daily metrics",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    }
  ],
  "connections": {
    "Daily at 23:55": { "main": [[{ "node": "Collect daily metrics", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
