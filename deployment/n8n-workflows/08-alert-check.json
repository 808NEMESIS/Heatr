{
  "name": "08 — Metric Alert Check",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 8 * * *" }]
        }
      },
      "name": "Daily at 08:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "url": "={{ $env.HEATR_BASE_URL }}/alerts?include_read=false&limit=10",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {}
      },
      "name": "Get unread alerts",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    }
  ],
  "connections": {
    "Daily at 08:00": { "main": [[{ "node": "Get unread alerts", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "_comment": "Alerts are created automatically by check_metric_alerts() at end of daily metrics collection. This workflow simply reads them — extend with Slack/email notification node as needed."
}
